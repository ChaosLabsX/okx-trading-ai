# OKX signal checker - VPS environment. Copy to `.env` in the repo root
# (C:\OKXAI\.env) and fill in your real values. Never commit .env - it is
# gitignored. These are the same secrets you set as GitHub Actions Secrets;
# copy them across.

# Telegram (the OKX bot - NOT the Forex one)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OKX API (the account this bot trades)
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Supabase (the OKX project - NOT the Forex one)
SUPABASE_URL=
SUPABASE_KEY=

# Anthropic - Claude Haiku trade advisor. Optional: auto-trade sizing is
# skipped if unset, the rest of the worker still runs.
CLAUDE_API_KEY=
